#!/usr/bin/env bash
# team-layout — agentic-team 4-pane tmux 레이아웃 생성
#
# 본 명세 SPEC.md §8 의 dashboard 레이아웃 진입점. tmux 안에서 호출.
# §14 stage a (audit-codex) 추가 후 우측 컬럼 1/3 균등 3-pane 으로 확장.
#
#   ┌─────────────────────────┬─────────────────────┐
#   │                         │  Gemini · researcher│
#   │                         │  (latest-gemini.log)│
#   │                         ├─────────────────────┤
#   │    Claude PM            │  Codex · reviewer   │
#   │    (현재 pane 유지)      │  (latest-codex.log) │
#   │                         ├─────────────────────┤
#   │                         │  Auditor (ceo|cto)  │
#   │                         │  (latest-audit.log) │
#   └─────────────────────────┴─────────────────────┘
#
# 호출:
#   직접:        team-layout
#   tmux 단축키: prefix + R   (tmux/keybinding.conf 참조)

set -euo pipefail
caller="team-layout"

# ---- self-locate (stow 심링크 대응) -------------------------------------
if command -v readlink >/dev/null 2>&1 && readlink -f / >/dev/null 2>&1; then
  _self=$(readlink -f "${BASH_SOURCE[0]}")
else
  _self=$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
    "${BASH_SOURCE[0]}")
fi
_root=$(cd "$(dirname "$_self")/.." && pwd)

# ---- tmux 안인지 확인 --------------------------------------------------
if [ -z "${TMUX:-}" ]; then
  printf '[%s] not inside tmux — open a tmux session first\n' "$caller" >&2
  exit 1
fi

# ---- 로그 디렉토리 결정 (watcher 들이 읽을 위치) -----------------------
# shellcheck source=../lib/team-name.sh
source "${_root}/lib/team-name.sh"
# shellcheck source=../lib/log-root.sh
source "${_root}/lib/log-root.sh"

team=$(team_name)
root=$(log_root)
log_dir="${root}/${team}"
mkdir -p "$log_dir"

# ---- 이미 분할된 윈도우면 경고만 (강제 진행) ---------------------------
pane_count=$(tmux display-message -p '#{window_panes}')
if [ "$pane_count" -gt 1 ]; then
  printf '[%s] window already has %d panes — appending dashboard panes anyway\n' \
    "$caller" "$pane_count" >&2
fi

# ---- 분할 명령 조립 ----------------------------------------------------
# pane 안에서 실행할 명령. exec 로 셸 갈아치워 Ctrl+D 시 dangling shell X.
# bash -c 안에서 lib 를 source 한 뒤 dashboard_watch 호출.
# log_dir 인자는 따옴표로 escape — 공백·특수문자 보호.
build_cmd() {
  local which="$1"
  printf 'exec bash -c %q' \
    "source '${_root}/lib/dashboard-render.sh'; dashboard_watch '${which}' '${log_dir}'"
}

# 우측 40% pane 추가 → gemini watcher (현재는 풀 높이)
tmux split-window -h -l 40% "$(build_cmd gemini)"

# focus = gemini pane. -l 67% 로 새 pane (codex) 가 67% 차지 → gemini 33% 로 위쪽 압축.
tmux split-window -v -l 67% "$(build_cmd codex)"

# focus = codex pane. -l 50% 로 새 pane (audit) 가 codex 의 절반 차지.
# 결과: 우측 컬럼이 ≈ 33% / 33.5% / 33.5% (gemini / codex / audit) 균등 3분할.
tmux split-window -v -l 50% "$(build_cmd audit)"

# focus 를 좌측(PM) pane 으로 복귀 — 사용자는 즉시 자연어 입력 가능
tmux select-pane -L

printf '[%s] team=%s · log_dir=%s · 4-pane (PM | gemini/codex/audit)\n' \
  "$caller" "$team" "$log_dir"
