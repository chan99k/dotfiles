#!/usr/bin/env bash
# ask-gemini — Gemini Researcher 워커 호출 wrapper
#
# 본 명세 SPEC.md §3 인터페이스(위치/옵션 둘 다)·§4 로그·§5 graphify·
# §7 trust-boundary 통합 진입점.
#
# Stateless one-shot. 라이브러리·API 사실 질의 단발 응답. PM 이 NEED-RESEARCH
# 합본 누적 책임 — wrapper 는 단일 응답만 stdout 으로 뱉음.
#
# 호출 형태:
#   ask-gemini "FastAPI 0.115 dependency injection 변경점"
#   ask-gemini --query "..." [--with-context FILE] [--max-words N] [--no-graphify]
#
# 종료 코드:
#   0   정상
#   64  EX_USAGE       — 인자 오류
#   66  EX_NOINPUT     — --with-context 파일 부재
#   그 외 gemini CLI 의 종료 코드 그대로 전달

set -euo pipefail

caller="ask-gemini"

# ---- self-locate (stow 심링크 경유 호출 대응) ---------------------------
if command -v readlink >/dev/null 2>&1 && readlink -f / >/dev/null 2>&1; then
  _self=$(readlink -f "${BASH_SOURCE[0]}")
else
  _self=$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
    "${BASH_SOURCE[0]}")
fi
_root=$(cd "$(dirname "$_self")/.." && pwd)

# ---- 라이브러리 로드 ----------------------------------------------------
# shellcheck source=../lib/team-name.sh
source "${_root}/lib/team-name.sh"
# shellcheck source=../lib/log-root.sh
source "${_root}/lib/log-root.sh"
# shellcheck source=../lib/trust-boundary.sh
source "${_root}/lib/trust-boundary.sh"
# shellcheck source=../lib/graphify.sh
source "${_root}/lib/graphify.sh"

# ---- usage --------------------------------------------------------------
usage() {
  cat <<EOF
ask-gemini — Gemini Researcher 워커 호출 (one-shot)

Usage:
  ask-gemini "query text"
  ask-gemini --query "query text" [--with-context FILE] [--max-words N] [--no-graphify]

Options:
  --query TEXT          질의 텍스트 (위치 인자 대안)
  --with-context FILE   배경 컨텍스트 파일 — <user_context> 로 첨부
  --max-words N         답변 단어 수 soft cap (프롬프트에 자연어 제약 주입)
  --no-graphify         graphify 자동 첨부 비활성화
  -h, --help            본 도움말

Environment:
  AGENTIC_TEAM_LOG_ROOT       로그 루트 override (default: <git-top>/.agentic-team/log)
  AGENTIC_TEAM_NAME           팀 이름 override (default: tmux session 또는 "solo")
  AGENTIC_TEAM_GRAPHIFY_DIR   graphify-out 디렉토리 override
  AGENTIC_TEAM_GRAPHIFY_MAX_BYTES  graphify 발췌 cap (default: 8192)
EOF
}

# ---- 인자 파싱 ----------------------------------------------------------
query=""
with_context=""
max_words=""
no_graphify=0

if [ $# -eq 0 ]; then
  usage >&2
  exit 64
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
  -*)
    while [ $# -gt 0 ]; do
      case "$1" in
        --query)
          [ $# -ge 2 ] || { printf '[%s] --query needs a value\n' "$caller" >&2; exit 64; }
          query="$2"; shift 2
          ;;
        --with-context)
          [ $# -ge 2 ] || { printf '[%s] --with-context needs a path\n' "$caller" >&2; exit 64; }
          with_context="$2"; shift 2
          ;;
        --max-words)
          [ $# -ge 2 ] || { printf '[%s] --max-words needs a value\n' "$caller" >&2; exit 64; }
          # 정수 검증
          case "$2" in
            ''|*[!0-9]*)
              printf '[%s] --max-words must be a positive integer: %s\n' "$caller" "$2" >&2
              exit 64
              ;;
          esac
          max_words="$2"; shift 2
          ;;
        --no-graphify)
          no_graphify=1; shift
          ;;
        -h|--help)
          usage; exit 0
          ;;
        *)
          printf '[%s] unknown option: %s\n' "$caller" "$1" >&2
          exit 64
          ;;
      esac
    done
    [ -n "$query" ] || { printf '[%s] --query is required in option mode\n' "$caller" >&2; exit 64; }
    ;;
  *)
    [ $# -eq 1 ] || { printf '[%s] positional mode takes exactly 1 arg; use --query for option mode\n' "$caller" >&2; exit 64; }
    query="$1"
    ;;
esac

# ---- 컨텍스트 결정 ------------------------------------------------------
team=$(team_name)
root=$(log_root)
ts=$(date +'%Y%m%d-%H%M%S')
log_dir="${root}/${team}"
mkdir -p "$log_dir"
log_file="${log_dir}/gemini-${ts}.log"
latest_link="${log_dir}/latest-gemini.log"

# ---- prompt 조립 (trust-boundary 적용) ----------------------------------
# 1) 시스템 프롬프트 = roles/researcher.md
sys_prompt=$(cat "${_root}/roles/researcher.md")

# 2) 질의 (untrusted)
query_safe=$(strip_closing_tags 'user_question' "$query")

# 3) (선택) 단어 수 soft cap — 프롬프트에 자연어 제약 추가.
# 본 데모에 없는 본 시스템 추가 기능. role.md 의 default(<400 단어)를 override.
length_directive=""
if [ -n "$max_words" ]; then
  length_directive=$(printf '\n<length_constraint>Aim for under %s words.</length_constraint>' "$max_words")
fi

# 4) (선택) 배경 컨텍스트 파일 첨부 (untrusted)
context_block=""
if [ -n "$with_context" ]; then
  [ -f "$with_context" ] || {
    printf '[%s] context file not found: %s\n' "$caller" "$with_context" >&2
    exit 66
  }
  context_raw=$(cat "$with_context")
  context_safe=$(strip_closing_tags 'user_context' "$context_raw")
  context_block=$(printf '\n<user_context>\n%s\n</user_context>\n' "$context_safe")
fi

# 5) (선택) graphify 컨텍스트 자동 첨부
graphify_block=""
graphify_status="none"
if [ "$no_graphify" -eq 0 ]; then
  if excerpt=$(graphify_context_excerpt); then
    excerpt_safe=$(strip_closing_tags 'graphify_context' "$excerpt")
    graphify_block=$(printf '\n<graphify_context>\n%s\n</graphify_context>\n' "$excerpt_safe")
    graphify_status="attached"
  else
    printf '[%s] no graph for this project (graphify-out/graph.json not found)\n' "$caller" >&2
    graphify_status="absent"
  fi
else
  graphify_status="opted-out"
fi

# 6) 최종 prompt
prompt=$(printf '%s%s\n\n<user_question>\n%s\n</user_question>%s%s\n' \
  "$sys_prompt" "$length_directive" "$query_safe" "$context_block" "$graphify_block")

# ---- 로그 헤더 ----------------------------------------------------------
{
  printf '=== ask-gemini %s ===\n' "$ts"
  printf 'team: %s\n' "$team"
  printf 'cwd: %s\n' "$PWD"
  printf 'query: %s\n' "$query"
  printf 'with-context: %s\n' "${with_context:-<none>}"
  printf 'max-words: %s\n' "${max_words:-<none>}"
  printf 'graphify: %s\n' "$graphify_status"
  printf '\n--- PROMPT ---\n%s\n\n--- RESPONSE ---\n' "$prompt"
} > "$log_file"

# ---- Gemini 호출 --------------------------------------------------------
# --approval-mode plan → 리서처는 read-only. 외부 도구(websearch 등)는 도구
# 정책에 따라 허용/차단. role.md 가 출처 인용 의무 명시 — model 레벨 보강.
# -o text → gemini-cli default 가 JSON 이므로 *명시* 로 plain text 강제.
# 본 명시가 없으면 dashboard_extract_gemini 가 JSON 의 `{` 를 lead 로 잘못 추출.
# stdin 은 비워둠 — gemini-cli 는 stdin 이 있으면 -p 뒤에 append 함.
rc=0
gemini -p "$prompt" --approval-mode plan -o text </dev/null 2>&1 \
  | tee -a "$log_file" \
  || rc=$?

# 종료 마커 + latest 심링크 갱신
printf '\n--- END (rc=%d) ---\n' "$rc" >> "$log_file"
ln -sfn "$(basename "$log_file")" "$latest_link"

exit "$rc"
