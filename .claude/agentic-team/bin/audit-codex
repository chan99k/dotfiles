#!/usr/bin/env bash
# audit-codex — Codex Auditor 워커 호출 wrapper (ceo|cto 페르소나)
#
# SPEC.md §14 stage a — 전략적 관점 감사. ask-codex 와 *동일한 Output Contract* 를
# 사용하되 시스템 프롬프트가 roles/auditor.md 로 바뀌고, prompt 에
# <persona> 블록이 추가됨. 대시보드/로그 파서는 그대로 호환.
#
# Stateless one-shot. 매 호출마다 페르소나(ceo|cto) 명시 필수.
# 루프 제어는 PM 책임 (NEED RESEARCH 처리 동일).
#
# 호출 형태:
#   audit-codex --persona ceo  "감사 대상 텍스트"
#   audit-codex --persona cto  --focus "..." [--with-research FILE] [--no-graphify]
#
# 종료 코드:
#   0   정상
#   64  EX_USAGE       — 인자 오류 (페르소나 누락/오타 포함)
#   66  EX_NOINPUT     — --with-research 파일 부재
#   그 외 codex CLI 의 종료 코드 그대로 전달

set -euo pipefail

caller="audit-codex"

# ---- self-locate (stow 심링크 경유 호출 대응) ---------------------------
if command -v readlink >/dev/null 2>&1 && readlink -f / >/dev/null 2>&1; then
  _self=$(readlink -f "${BASH_SOURCE[0]}")
else
  _self=$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
    "${BASH_SOURCE[0]}")
fi
_root=$(cd "$(dirname "$_self")/.." && pwd)

# ---- 라이브러리 로드 ----------------------------------------------------
# shellcheck source=../lib/team-name.sh
source "${_root}/lib/team-name.sh"
# shellcheck source=../lib/log-root.sh
source "${_root}/lib/log-root.sh"
# shellcheck source=../lib/trust-boundary.sh
source "${_root}/lib/trust-boundary.sh"
# shellcheck source=../lib/graphify.sh
source "${_root}/lib/graphify.sh"

# ---- usage --------------------------------------------------------------
usage() {
  cat <<EOF
audit-codex — Codex Auditor 워커 호출 (one-shot, persona 필수)

Usage:
  audit-codex --persona <ceo|cto> "focus text"
  audit-codex --persona <ceo|cto> --focus "focus text" [--with-research FILE] [--no-graphify]

Options:
  --persona NAME        감사 페르소나 (ceo | cto) — 필수
  --focus TEXT          감사 대상 텍스트 (위치 인자 대안)
  --with-research FILE  Gemini 합본 마크다운 — <research_context> 로 첨부
  --no-graphify         graphify 자동 첨부 비활성화
  -h, --help            본 도움말

Persona:
  ceo   — 비즈니스/전략 관점 (context-aware)
          · personal system : 우선순위·기회비용·체감 생산성·이번 분기 목표
          · real product   : 수익·일정·UX·외부 인식·경쟁 포지셔닝
  cto   — 기술/시스템 관점 (tech-debt·확장성·운영 비용·인지 부하·lock-in·테스트 용이성)

Environment:
  AGENTIC_TEAM_LOG_ROOT       로그 루트 override (default: <git-top>/.agentic-team/log)
  AGENTIC_TEAM_NAME           팀 이름 override (default: tmux session 또는 "solo")
  AGENTIC_TEAM_GRAPHIFY_DIR   graphify-out 디렉토리 override
  AGENTIC_TEAM_GRAPHIFY_MAX_BYTES  graphify 발췌 cap (default: 8192)
EOF
}

# ---- 인자 파싱 ----------------------------------------------------------
persona=""
focus=""
with_research=""
no_graphify=0

if [ $# -eq 0 ]; then
  usage >&2
  exit 64
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
esac

# 옵션 + 위치 인자 혼합 파싱.
# --persona 는 항상 옵션. --focus 미지정 시 마지막 비-옵션 위치 인자 1개를 focus 로.
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    --persona)
      [ $# -ge 2 ] || { printf '[%s] --persona needs a value (ceo|cto)\n' "$caller" >&2; exit 64; }
      persona="$2"; shift 2
      ;;
    --focus)
      [ $# -ge 2 ] || { printf '[%s] --focus needs a value\n' "$caller" >&2; exit 64; }
      focus="$2"; shift 2
      ;;
    --with-research)
      [ $# -ge 2 ] || { printf '[%s] --with-research needs a path\n' "$caller" >&2; exit 64; }
      with_research="$2"; shift 2
      ;;
    --no-graphify)
      no_graphify=1; shift
      ;;
    -h|--help)
      usage; exit 0
      ;;
    --)
      shift
      while [ $# -gt 0 ]; do positional+=("$1"); shift; done
      ;;
    -*)
      printf '[%s] unknown option: %s\n' "$caller" "$1" >&2
      exit 64
      ;;
    *)
      positional+=("$1"); shift
      ;;
  esac
done

# 페르소나 필수 + 화이트리스트 검증
case "$persona" in
  ceo|cto) ;;
  '')
    printf '[%s] --persona is required (ceo|cto)\n' "$caller" >&2
    exit 64
    ;;
  *)
    printf '[%s] unknown persona: %s (allowed: ceo, cto)\n' "$caller" "$persona" >&2
    exit 64
    ;;
esac

# focus 결정 — --focus 우선, 없으면 위치 인자 1개
if [ -z "$focus" ]; then
  case "${#positional[@]}" in
    0)
      printf '[%s] focus is required (positional or --focus)\n' "$caller" >&2
      exit 64
      ;;
    1)
      focus="${positional[0]}"
      ;;
    *)
      printf '[%s] too many positional args (%d); use --focus or quote into one arg\n' \
        "$caller" "${#positional[@]}" >&2
      exit 64
      ;;
  esac
elif [ "${#positional[@]}" -ne 0 ]; then
  printf '[%s] cannot mix --focus with positional args\n' "$caller" >&2
  exit 64
fi

# ---- 컨텍스트 결정 ------------------------------------------------------
team=$(team_name)
root=$(log_root)
ts=$(date +'%Y%m%d-%H%M%S')
log_dir="${root}/${team}"
mkdir -p "$log_dir"
# 별도 네임스페이스 — codex-* 와 구분되어 dashboard/grep 으로 분리 추적 가능.
log_file="${log_dir}/audit-${ts}.log"
latest_link="${log_dir}/latest-audit.log"

# ---- prompt 조립 (trust-boundary 적용) ----------------------------------
# 1) 시스템 프롬프트 = roles/auditor.md
sys_prompt=$(cat "${_root}/roles/auditor.md")

# 2) 페르소나 — 화이트리스트 통과 했지만 trust-boundary 일관성 위해 strip 도 적용
persona_safe=$(strip_closing_tags 'persona' "$persona")

# 3) 감사 대상 (untrusted)
focus_safe=$(strip_closing_tags 'review_target' "$focus")

# 4) (선택) 연구 결과 (untrusted)
research_block=""
if [ -n "$with_research" ]; then
  [ -f "$with_research" ] || {
    printf '[%s] research file not found: %s\n' "$caller" "$with_research" >&2
    exit 66
  }
  research_raw=$(cat "$with_research")
  research_safe=$(strip_closing_tags 'research_context' "$research_raw")
  research_block=$(printf '\n<research_context>\n%s\n</research_context>\n' "$research_safe")
fi

# 5) (선택) graphify 컨텍스트
graphify_block=""
graphify_status="none"
if [ "$no_graphify" -eq 0 ]; then
  if excerpt=$(graphify_context_excerpt); then
    excerpt_safe=$(strip_closing_tags 'graphify_context' "$excerpt")
    graphify_block=$(printf '\n<graphify_context>\n%s\n</graphify_context>\n' "$excerpt_safe")
    graphify_status="attached"
  else
    printf '[%s] no graph for this project (graphify-out/graph.json not found)\n' "$caller" >&2
    graphify_status="absent"
  fi
else
  graphify_status="opted-out"
fi

# 6) 최종 prompt — <persona> 가 <review_target> 앞에 옴 (페르소나 락-인 우선 적용)
prompt=$(printf '%s\n\n<persona>\n%s\n</persona>\n\n<review_target>\n%s\n</review_target>%s%s\n' \
  "$sys_prompt" "$persona_safe" "$focus_safe" "$research_block" "$graphify_block")

# ---- 로그 헤더 ----------------------------------------------------------
{
  printf '=== audit-codex %s ===\n' "$ts"
  printf 'team: %s\n' "$team"
  printf 'cwd: %s\n' "$PWD"
  printf 'persona: %s\n' "$persona"
  printf 'focus: %s\n' "$focus"
  printf 'with-research: %s\n' "${with_research:-<none>}"
  printf 'graphify: %s\n' "$graphify_status"
  printf '\n--- PROMPT ---\n%s\n\n--- RESPONSE ---\n' "$prompt"
} > "$log_file"

# ---- Codex 호출 ---------------------------------------------------------
# 동일 sandbox/플래그. 감사도 read-only — 파일 수정 권한 없음.
rc=0
printf '%s' "$prompt" \
  | codex exec --skip-git-repo-check -s read-only - 2>&1 \
  | tee -a "$log_file" \
  || rc=$?

printf '\n--- END (rc=%d) ---\n' "$rc" >> "$log_file"
ln -sfn "$(basename "$log_file")" "$latest_link"

exit "$rc"
