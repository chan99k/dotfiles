{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo :*)",
      "Bash(dd :*)",
      "Bash(mkfs:*)",
      "Bash(diskutil erase:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown -R:*)",
      "Bash(killall -9:*)",
      "Bash(kill -9 -1:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f :*)",
      "Bash(docker system prune:*)",
      "Bash(kubectl delete namespace:*)",
      "Bash(kubectl delete ns :*)",
      "Bash(eval :*)",
      "Bash(bash -c:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(node -e:*)",
      "Bash(shred:*)",
      "Bash(srm:*)",
      "Bash(gshred:*)",
      "Bash(nmap:*)",
      "Bash(hping3:*)",
      "Bash(tcpdump:*)",
      "Bash(defaults write:*)",
      "Bash(launchctl load:*)",
      "Bash(launchctl unload:*)",
      "Bash(launchctl submit:*)",
      "Bash(scutil:*)",
      "Bash(systemsetup:*)",
      "Bash(dscl:*)",
      "Bash(npm install -g:*)",
      "Bash(npm i -g:*)",
      "Bash(pip install:*)",
      "Bash(gem install:*)",
      "Bash(cargo install:*)",
      "Bash(history -c:*)",
      "Bash(unset HISTFILE:*)",
      "Bash(crontab -r:*)",
      "Bash(at :*)",
      "Bash(ssh :*)",
      "Bash(scp :*)",
      "Bash(diskutil:*)",
      "Bash(fdisk:*)",
      "Bash(hdiutil:*)",
      "Bash(mount :*)",
      "Bash(umount:*)",
      "Bash(truncate:*)"
    ]
  },
  "env": {
    "MAX_THINKING_TOKENS": "16000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "BASH_MAX_OUTPUT_LENGTH": "1000000",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-5-20250929",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code - PreToolUse\" -message \"도구 실행 준비 중: $CLAUDE_TOOL_NAME\" -sound default"
          }
        ]
      },
      {
        "matcher": "bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"\\(.tool_input.command) - \\(.tool_input.description // \"No description\")\"' >> ~/.claude/bash-command-log.txt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"Claude Code - Stop\" -message \"Claude 응답이 완료되었습니다\" -sound default -timeout 30"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/UserPromptSubmit/append_ultrathink.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "serena@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "생각하는 중",
      "분석하는 중",
      "코드 읽는 중",
      "파일 탐색 중",
      "작성하는 중",
      "검토하는 중",
      "실행하는 중",
      "검색하는 중",
      "변경 적용 중",
      "테스트 확인 중",
      "구조 파악 중",
      "계획 수립 중",
      "의존성 추적 중",
      "리팩토링 중",
      "디버깅 중",
      "패턴 매칭 중",
      "컨텍스트 수집 중",
      "해결책 모색 중",
      "최적화 중",
      "연결고리 찾는 중"
    ]
  },
  "alwaysThinkingEnabled": true
}
