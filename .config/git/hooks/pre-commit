#!/usr/bin/env bash
# Global pre-commit hook: gitleaks + local hook chaining
# Installed: 2026-03-05

# 1) gitleaks secret scanning
if command -v gitleaks &>/dev/null; then
    gitleaks git --pre-commit --staged --no-banner 2>&1
    exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo ""
        echo "🚨 gitleaks: secrets detected in staged changes!"
        echo "   Fix the issue or use 'git commit --no-verify' to bypass (not recommended)."
        echo ""
        exit $exit_code
    fi
fi

# 2) Delegate to project hook manager
TOPLEVEL="$(git rev-parse --show-toplevel 2>/dev/null)"

# lefthook (lefthook.yml present): drive it directly so we don't need a
# per-project core.hooksPath override (which would bypass this global hook).
if [ -n "$TOPLEVEL" ] && [ -f "$TOPLEVEL/lefthook.yml" ] && command -v lefthook &>/dev/null; then
    # --no-auto-install: skip lefthook's self-sync (it would warn about the
    # global core.hooksPath, which is intentional in this dotfiles setup).
    lefthook run pre-commit --no-auto-install || exit $?
    exit 0
fi

# Fallback for non-lefthook repos: chain local hooks
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)"

# Standard .git/hooks/pre-commit
LOCAL_HOOK="$GIT_DIR/hooks/pre-commit"
if [ -x "$LOCAL_HOOK" ]; then
    "$LOCAL_HOOK" "$@" || exit $?
fi

# Husky (.husky/pre-commit)
HUSKY_HOOK="$TOPLEVEL/.husky/pre-commit"
if [ -x "$HUSKY_HOOK" ]; then
    "$HUSKY_HOOK" "$@" || exit $?
fi
